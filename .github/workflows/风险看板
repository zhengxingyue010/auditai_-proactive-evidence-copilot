/* Case Filter */
function rCases(){
  const modeF=document.getElementById('filterMode').value;
  const progF=document.getElementById('filterProg').value;
  const lvF=document.getElementById('filterLv').value;
  let filtered=data.cases.filter(c=>{
    if(modeF!=='all'&&c.pid!==modeF)return false;
    if(lvF!=='all'&&c.lv!==lvF)return false;
    if(progF!=='all'){
      if(progF==='early'&&(c.prog>50||c.nodes.length>2&&c.nodes[2]==='done'))return false;
      if(progF==='mid'&&(c.prog<=50||c.prog>80))return false;
      if(progF==='late'&&(c.prog<=80))return false;
      if(progF==='review'&&(c.st.indexOf('复核')===-1))return false;
    }
    return true;
  });
  const row=document.getElementById('casesRow');
  if(filtered.length===0){row.innerHTML='<div style="flex:1;display:flex;align-items:center;justify-content:center;color:var(--t4);font-size:13px;font-weight:700">无匹配案例</div>';return;}
  row.innerHTML='';
  filtered.forEach(c=>{
    const idx=data.cases.indexOf(c);
    const cd=document.createElement('div');cd.className='case-card';cd.onclick=()=>showDet(idx);
    const tlH=c.nLbl.map((l,i)=>{
      const st=c.nodes[i]==='done'?'done':c.nodes[i]==='active'?'act':'pend';
      const stText=c.nodes[i]==='done'?'已完成':c.nodes[i]==='active'?'进行中':'待执行';
      return`<div class="case-tl-item"><div class="case-tl-dot ${st}"></div><div class="case-tl-text"><span class="case-tl-name">${l}</span><span class="case-tl-stat ${st}">${stText}</span></div></div>`;
    }).join('');
    cd.innerHTML=`<div class="case-bar ${c.lv}"></div><div class="case-body">
<div class="case-hd"><span class="case-id">${c.id}</span><span class="case-badge ${c.lv}">${c.lv.toUpperCase()} ${c.lvN}</span></div>
<div class="case-name">${c.name}</div>
<div class="case-meta"><div class="case-mi">风险模式: <span>${c.pid}</span></div><div class="case-mi">${c.accs?'关联账号':'关联订单'}: <span>${c.accs||c.ords}个</span> | 金额: <span>¥${c.amt}</span></div><div class="case-mi">置信度: <span>${c.conf}</span></div><div class="case-mi">复杂度: <span>${c.cx}</span></div></div>
<div class="case-sig">${c.sig}</div>
<div class="case-tl">${c.tl}</div>
<div class="case-prog"><div class="case-prog-hd"><span class="case-prog-lb">追证进度</span><span class="case-prog-v">${c.prog}%</span></div><div class="case-prog-trk"><div class="case-prog-f ${c.lv}" style="width:${c.prog}%"></div></div></div>
<div class="case-st"><span class="bl">●</span> ${c.st} · 已${c.el} / 剩${c.rem}</div>
<div class="case-bottom"><div class="case-timeline">${tlH}</div><div class="case-radar-wrap"><canvas id="cr${idx}"></canvas></div></div></div>`;
    row.appendChild(cd);
    setTimeout(()=>{
      const rc=document.getElementById(`cr${idx}`);if(!rc)return;
      const wrap=rc.parentElement;
      const ww=wrap.offsetWidth,wh=wrap.offsetHeight;
      const size=Math.min(ww,wh);
      rc.width=size*2;rc.height=size*2;rc.style.width=size+'px';rc.style.height=size+'px';
      const cx=rc.getContext('2d');cx.scale(2,2);
      const C=size/2,cy=size/2,R=size/2-8;
      const as=(Math.PI*2)/6,mxT=16;
      // Grid layers - white highlighted with glow
      for(let r=1;r<=5;r++){const rr=(R/5)*r;cx.beginPath();for(let j=0;j<=6;j++){const a=as*j-Math.PI/2,xx=C+rr*Math.cos(a),yy=cy+rr*Math.sin(a);if(j===0)cx.moveTo(xx,yy);else cx.lineTo(xx,yy)}cx.closePath();cx.strokeStyle=`rgba(255,255,255,${.03+r*.025})`;cx.lineWidth=1.5;cx.shadowColor='rgba(255,255,255,.08)';cx.shadowBlur=6;cx.stroke();cx.shadowBlur=0}
      // Axis lines - white highlighted
      for(let j=0;j<6;j++){const a=as*j-Math.PI/2;cx.beginPath();cx.moveTo(C,cy);cx.lineTo(C+R*Math.cos(a),cy+R*Math.sin(a));cx.strokeStyle='rgba(255,255,255,.08)';cx.lineWidth=1.2;cx.stroke()}
      const cls=['#ff4d4f','#ff9c3e','#00A376'];const glw=cls[data.cases.indexOf(c)]||'#00A376';
      // Data polygon with strong glow
      cx.save();cx.shadowColor=glw;cx.shadowBlur=25;
      cx.beginPath();c.rT.forEach((v,i)=>{const a=as*i-Math.PI/2,rr=(v/mxT)*R,xx=C+rr*Math.cos(a),yy=cy+rr*Math.sin(a);if(i===0)cx.moveTo(xx,yy);else cx.lineTo(xx,yy)});cx.closePath();
      cx.strokeStyle=glw;cx.lineWidth=3;cx.stroke();cx.fillStyle=glw+'30';cx.fill();
      cx.restore();
      // Data points with glow
      c.rT.forEach((v,i)=>{const a=as*i-Math.PI/2,rr=(v/mxT)*R,xx=C+rr*Math.cos(a),yy=cy+rr*Math.sin(a);cx.beginPath();cx.arc(xx,yy,5,0,Math.PI*2);cx.shadowColor=glw;cx.shadowBlur=10;cx.fillStyle='#fff';cx.fill();cx.shadowBlur=0})
    },80);
  });
}
